{
  "manifest_version": "0.1.0",
  "metadata": {
    "name": "Purple Coding Agent",
    "description": "An MCTS-guided software engineering agent using Qwen 7B."
  },
  "config_schema": {
    "type": "object",
    "properties": {
      "hf_token": {
        "type": "string",
        "title": "Hugging Face API Token",
        "secret": true
      }
    },
    "required": ["hf_token"]
  },
  "program": {
    "image": "rimodock/purple-coding-agent:latest",
    "entrypoint": "python src/server.py", // Direct path from /app
    "network": {
      "endpoints": [
        {
          "name": "a2a_endpoint",
          "port": 9010
        }
      ]
    },
    "env": {
      "LLM_BASE_URL": "https://router.huggingface.co/v1",
      "MODEL_NAME": "Qwen/Qwen2.5-Coder-7B-Instruct",
      "USE_MCTS": "true",
      "PYTHONPATH": "/app/src", // This ensures 'import agent' still works
      "LLM_API_KEY": "${config.hf_token}"
    }
  },
  "provides": {
    "a2a": {
      "kind": "a2a",
      "endpoint": "a2a_endpoint"
    }
  },
  "exports": {
    "a2a": "a2a"
  }
}