{
  "manifest_version": "0.1.0",
  "program": {
    "image": "rimodock/purple-coding-agent:latest",
    "entrypoint": "python src/server.py",
    "network": {
      "endpoints": [
        {
          "name": "a2a",
          "port": 9010
        }
      ]
    },
    "env": {
      "LLM_BASE_URL": "https://router.huggingface.co/v1",
      "MODEL_NAME": "Qwen/Qwen2.5-Coder-7B-Instruct",
      "USE_MCTS": "true",
      "HF_TOKEN": "${config.hf_token}"
    }
  },
  "config_schema": {
    "type": "object",
    "properties": {
      "hf_token": {
        "type": "string",
        "title": "Hugging Face Token",
        "secret": true
      }
    },
    "required": ["hf_token"]
  },
  "provides": {
    "a2a": {
      "kind": "a2a",
      "endpoint": "a2a"
    }
  },
  "exports": {
    "a2a": "a2a"
  }
}
// Triggering fresh evaluation run #1
